{
  "name": "bibleapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "tsx node_modules/knex/bin/cli.js --knexfile src/lib/db/knexfile.ts migrate:latest",
    "db:rollback": "tsx node_modules/knex/bin/cli.js --knexfile src/lib/db/knexfile.ts migrate:rollback",
    "db:seed": "tsx node_modules/knex/bin/cli.js --knexfile src/lib/db/knexfile.ts seed:run",
    "db:import:arc": "tsx src/scripts/import-arc.ts",
    "db:import:chapter-contexts": "tsx src/scripts/import-chapter-contexts.ts",
    "db:reset": "pnpm db:rollback --all && pnpm db:migrate && pnpm db:seed",
    "prepare": "husky",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "argon2": "^0.44.0",
    "knex": "^3.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.0.10",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.16.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.1.5",
    "autoprefixer": "^10.4.22",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "^10.1.7",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.2",
    "postcss": "^8.5.6",
    "prettier": "^3.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5",
    "vitest": "^3.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
