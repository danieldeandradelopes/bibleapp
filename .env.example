# Postgres (use DATABASE_URL ou os campos separados abaixo)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=bibleapp
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10

# Auth
AUTH_SECRET=
AUTH_URL=http://localhost:3030
ADMIN_EMAIL=admin@bibleapp.local
NEXT_PUBLIC_APP_URL=http://localhost:3030

# App
APP_NAME=BibleApp
DEFAULT_TRANSLATION_CODE=arc
NODE_ENV=development
